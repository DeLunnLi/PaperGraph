# PaperGraph Docker 部署环境变量
# 复制此文件为 .env,填入你的配置,然后 docker compose up -d --build

# ── LLM API (必填) ──
# 支持任何 OpenAI 兼容接口: DeepSeek / OpenAI / 通义千问 / AIHubMix 等
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_ID=deepseek-chat

# 如果代理导致 SSL/EOF 错误,设为 1
LLM_DISABLE_PROXY=1

# ── 可选: Embedding (用于记忆向量化,不填也能用) ──
# EMBED_MODEL_TYPE=dashscope
# EMBED_MODEL_NAME=text-embedding-v4
# EMBED_API_KEY=your-embed-key
# EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── 可选: 学术搜索 API ──
NCBI_EMAIL=
NCBI_API_KEY=
OPENALEX_MAILTO=

# ── 可选: Tavily 预搜索 ──
TAVILY_PRESEARCH_ENABLED=false
TAVILY_API_KEY=

# ── 可选: JWT 密钥 (不填则自动生成) ──
# PAPERGRAPH_JWT_SECRET=your-random-secret

# ── 应用配置 ──
APP_NAME=PaperGraph
DEBUG=false
LOG_LEVEL=INFO
